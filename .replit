modules = ["python-3.12", "bash"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"
packages = ["cairo", "ffmpeg-full", "freetype", "ghostscript", "gobject-introspection", "gtk3", "pkg-config", "qhull", "tcl", "tk"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python3 -c \"import requests, yfinance, openpyxl, docx, matplotlib, markdown; print('Daloopa Financial Analysis Toolkit ready.'); print('Python packages loaded successfully.'); print('Run scripts like: python3 infra/market_data.py quote AAPL')\""

[workflows.workflow.metadata]
outputType = "console"

[deployment]
deploymentTarget = "vm"
run = ["python3", "-c", "import requests, yfinance, openpyxl, docx, matplotlib, markdown; print('Daloopa Toolkit ready.')"]
